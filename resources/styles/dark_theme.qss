/* ================================================================
   KBS Monitoring v2 — 다크 테마 QSS
   색상 토큰: design/styles.css 기준
   primary accent: #D97757 (Claude orange)
   ================================================================ */

/* ── 기본 위젯 ─────────────────────────────────────────────────── */
QWidget {
    background-color: #17181b;
    color: #ececec;
    font-family: "Pretendard", "Malgun Gothic", "Segoe UI", sans-serif;
    font-size: 12px;
}

QMainWindow {
    background-color: #0f0f10;
}

/* ── 상단 바 ────────────────────────────────────────────────────── */
QWidget#topBar {
    background-color: #1e1f23;
    border-bottom: 1px solid #2a2b30;
}

QFrame#topBarSeparator {
    color: #3a3b42;
    background-color: #3a3b42;
    max-width: 1px;
}

/* ── 버튼 ───────────────────────────────────────────────────────── */
QPushButton {
    background-color: #26272c;
    color: #ececec;
    border: 1px solid #3a3b42;
    border-radius: 4px;
    padding: 4px 10px;
}

QPushButton:hover {
    background-color: #2d2e33;
    border-color: #D97757;
}

QPushButton:pressed {
    background-color: #D97757;
    color: #0f0f10;
}

QPushButton:checked {
    background-color: #D97757;
    color: #0f0f10;
    border-color: #B85E3F;
}

QPushButton:disabled {
    background-color: #1e1f23;
    color: #55565c;
    border-color: #2a2b30;
}

/* 감지 ON/OFF 버튼 */
QPushButton#btnDetection {
    font-weight: bold;
}

QPushButton#btnDetection:checked {
    background-color: #D97757;
    color: #0f0f10;
}

QPushButton#btnDetection:!checked {
    background-color: #26272c;
    color: #7d7e84;
}

/* 알림확인 버튼 — 알람 중에는 main_window에서 직접 스타일 주입 */
QPushButton#btnAlarmAck {
    font-weight: bold;
}

/* 정파 버튼 — signoff_state property 기반 */
QPushButton#btnSignoff {
    font-weight: bold;
    min-width: 100px;
}

QPushButton#btnSignoff[signoff_state="IDLE"] {
    background-color: #26272c;
    color: #7d7e84;
    border-color: #3a3b42;
}

QPushButton#btnSignoff[signoff_state="PREPARATION"] {
    background-color: #3a2a00;
    color: #e8a730;
    border-color: #e8a730;
}

QPushButton#btnSignoff[signoff_state="SIGNOFF"] {
    background-color: #5a1515;
    color: #ff6060;
    border-color: #e03131;
}

/* ── 슬라이더 ───────────────────────────────────────────────────── */
QSlider::groove:horizontal {
    background-color: #26272c;
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #D97757;
    width: 14px;
    height: 14px;
    border-radius: 7px;
    margin: -5px 0;
}

QSlider::sub-page:horizontal {
    background-color: #D97757;
    border-radius: 2px;
}

/* QSpinBox 위아래 버튼 숨기기 (CLAUDE.md 규칙) */
QSpinBox::up-button,
QSpinBox::down-button {
    width: 0;
    height: 0;
    border: none;
}

QSpinBox {
    background-color: #26272c;
    color: #ececec;
    border: 1px solid #3a3b42;
    border-radius: 4px;
    padding: 2px 4px;
}

/* ── 비디오 영역 ─────────────────────────────────────────────────── */
QWidget#videoArea {
    background-color: #0f0f10;
}

QLabel#videoLabel {
    background-color: #000000;
}

/* ── 로그 영역 ──────────────────────────────────────────────────── */
QWidget#logArea {
    background-color: #1e1f23;
}

QWidget#logHeaderArea {
    background-color: #17181b;
    border-bottom: 1px solid #3a3b42;
}

QLabel#logHeader {
    color: #D97757;
    font-weight: bold;
    font-size: 12px;
    letter-spacing: 1px;
}

QTextEdit#logList {
    background-color: #17181b;
    color: #ececec;
    border: none;
    font-family: "JetBrains Mono", "Consolas", monospace;
    font-size: 11px;
    padding: 2px 4px;
}

QPushButton#btnLogClear,
QPushButton#btnLogFolder {
    background-color: transparent;
    color: #7d7e84;
    border: 1px solid #3a3b42;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 11px;
}

QPushButton#btnLogClear:hover,
QPushButton#btnLogFolder:hover {
    border-color: #D97757;
    color: #D97757;
    background-color: rgba(217, 119, 87, 0.08);
}

/* ── 스플리터 ────────────────────────────────────────────────────── */
QSplitter#mainSplitter::handle {
    background-color: #3a3b42;
    width: 4px;
}

QSplitter#mainSplitter::handle:hover {
    background-color: #D97757;
}

/* ── 스크롤바 ────────────────────────────────────────────────────── */
QScrollBar:vertical {
    background-color: #1e1f23;
    width: 8px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #3a3b42;
    border-radius: 4px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #D97757;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0;
}

/* ── 정파 시간 레이블 ────────────────────────────────────────────── */
QLabel#lblSignoffTime {
    color: #7d7e84;
    font-size: 10px;
}

/* ── 감지현황 ────────────────────────────────────────────────────── */
QLabel#lblSummaryItem {
    color: #ececec;
    font-weight: bold;
}

/* ── 탭 위젯 (설정 다이얼로그용) ────────────────────────────────── */
QTabWidget::pane {
    background-color: #1e1f23;
    border: 1px solid #2a2b30;
}

QTabBar::tab {
    background-color: #17181b;
    color: #7d7e84;
    border: 1px solid #2a2b30;
    padding: 6px 14px;
    border-bottom: none;
}

QTabBar::tab:selected {
    background-color: #1e1f23;
    color: #D97757;
    border-bottom-color: #1e1f23;
}

QTabBar::tab:hover {
    color: #ececec;
}

/* ── 콤보박스 ────────────────────────────────────────────────────── */
QComboBox {
    background-color: #26272c;
    color: #ececec;
    border: 1px solid #3a3b42;
    border-radius: 4px;
    padding: 3px 8px;
}

QComboBox:hover {
    border-color: #D97757;
}

QComboBox QAbstractItemView {
    background-color: #26272c;
    color: #ececec;
    border: 1px solid #3a3b42;
    selection-background-color: #D97757;
    selection-color: #0f0f10;
}

/* ── 체크박스 ────────────────────────────────────────────────────── */
QCheckBox {
    spacing: 6px;
    color: #ececec;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #3a3b42;
    border-radius: 3px;
    background-color: #26272c;
}

QCheckBox::indicator:checked {
    background-color: #D97757;
    border-color: #B85E3F;
}

/* ── 텍스트 편집기 ───────────────────────────────────────────────── */
QLineEdit,
QTextEdit,
QPlainTextEdit {
    background-color: #26272c;
    color: #ececec;
    border: 1px solid #3a3b42;
    border-radius: 4px;
    padding: 2px 6px;
}

QLineEdit:focus,
QTextEdit:focus,
QPlainTextEdit:focus {
    border-color: #D97757;
}

/* ── 그룹박스 ────────────────────────────────────────────────────── */
QGroupBox {
    border: 1px solid #2a2b30;
    border-radius: 4px;
    margin-top: 8px;
    padding-top: 4px;
}

QGroupBox::title {
    color: #D97757;
    subcontrol-origin: margin;
    left: 8px;
    padding: 0 4px;
}

/* ── 레이블 ─────────────────────────────────────────────────────── */
QLabel {
    color: #ececec;
}

QLabel#lblTime {
    color: #D97757;
    font-size: 14px;
    font-weight: bold;
}

/* ── 설정 다이얼로그 섹션 박스 ─────────────────────────────────── */
QFrame#settingsSection {
    background-color: #1e1f24;
    border: 1px solid #3a3b42;
    border-radius: 8px;
}

QFrame#settingsSection QWidget {
    background-color: transparent;
}

QFrame#settingsSection QLineEdit,
QFrame#settingsSection QComboBox,
QFrame#settingsSection QSpinBox {
    background-color: #26272c;
    min-height: 24px;
    max-height: 26px;
    padding: 2px 8px;
    border: 1px solid #3a3b42;
    border-radius: 4px;
}

QFrame#settingsSection QLineEdit:focus,
QFrame#settingsSection QComboBox:focus {
    border-color: #D97757;
}

QFrame#settingsSection QPushButton {
    min-height: 24px;
    max-height: 28px;
    padding: 3px 12px;
    border-radius: 4px;
}

QFrame#settingsSection QCheckBox {
    color: #ececec;
    font-size: 12px;
    spacing: 6px;
}

QFrame#settingsSection QCheckBox::indicator {
    background-color: #26272c;
    border: 1px solid #3a3b42;
    border-radius: 3px;
    width: 14px;
    height: 14px;
}

QFrame#settingsSection QCheckBox::indicator:checked {
    background-color: #D97757;
    border-color: #B85E3F;
}

/* ── 설정창 공통 액션 버튼 ──────────────────────────────────────── */
QPushButton#btnPrimary {
    background-color: #D97757;
    color: #17181b;
    border: none;
    border-radius: 5px;
    padding: 6px 16px;
    font-size: 12px;
    font-weight: bold;
}

QPushButton#btnPrimary:hover {
    background-color: #E8906A;
}

QPushButton#btnPrimary:pressed {
    background-color: #B85E3F;
}

QPushButton#btnDanger {
    background-color: transparent;
    color: #cc3333;
    border: 1px solid #cc3333;
    border-radius: 5px;
    padding: 6px 16px;
    font-size: 12px;
    font-weight: bold;
}

QPushButton#btnDanger:hover {
    background-color: #cc3333;
    color: #17181b;
}

QPushButton#btnDanger:pressed {
    background-color: #992222;
    border-color: #992222;
    color: #17181b;
}

QPushButton#btnNeutral {
    background-color: transparent;
    color: #9d9ea4;
    border: 1px solid #3a3b3f;
    border-radius: 4px;
    padding: 2px 7px;
    font-size: 12px;
}

QPushButton#btnNeutral:hover {
    background-color: #2c2d31;
    color: #ececec;
    border-color: #5a5b60;
}

QPushButton#btnNeutral:pressed {
    background-color: #1e1f22;
}


QLabel#settingsSectionLabel {
    color: #D97757;
    font-weight: bold;
    font-size: 13px;
    padding: 0px;
    margin: 0px;
}

QLabel#settingsRowLabel {
    color: #ececec;
    font-size: 12px;
}

QLabel#settingsDesc {
    color: #7d7e84;
    font-size: 11px;
}

QFrame#settingsSep {
    color: #2a2b30;
    background-color: #2a2b30;
    max-height: 1px;
    border: none;
    margin: 4px 0;
}

/* ── ROI 감지영역 테이블 (설정창) ──────────────────────────────── */
QTableWidget#roiTable {
    background-color: #17181b;
    color: #ececec;
    border: 1px solid #D97757;
    border-radius: 3px;
    gridline-color: #3a3b42;
}

QTableWidget#roiTable QHeaderView::section {
    background-color: #2a1e18;
    color: #D97757;
    font-weight: bold;
    font-size: 11px;
    border: none;
    border-bottom: 1px solid #D97757;
    border-right: 1px solid #3a3b42;
    padding: 3px 4px;
}

QTableWidget#roiTable::item {
    border-bottom: 1px solid #2a2b30;
    padding: 2px 4px;
}

QTableWidget#roiTable::item:selected {
    background-color: #3a2a1e;
    color: #D97757;
}

/* ── 저장/불러오기 탭 액션 카드 ────────────────────────────────── */
QFrame#saveActionCard {
    background-color: #1e1f24;
    border: 1px solid #3a3b42;
    border-radius: 8px;
}

QFrame#saveActionCard:hover {
    border-color: #D97757;
}

QLabel#saveCardIcon {
    font-size: 22px;
    color: #D97757;
    background-color: transparent;
}

QLabel#saveCardTitle {
    font-size: 13px;
    font-weight: bold;
    color: #ececec;
    background-color: transparent;
}

QLabel#saveCardDesc {
    font-size: 11px;
    color: #7d7e84;
    background-color: transparent;
}

QPushButton#btnOutlineOrange {
    background-color: transparent;
    color: #D97757;
    border: 1px solid #D97757;
    border-radius: 5px;
    padding: 6px 18px;
    font-size: 12px;
    font-weight: bold;
    min-width: 90px;
}

QPushButton#btnOutlineOrange:hover {
    background-color: #D97757;
    color: #17181b;
}

QPushButton#btnOutlineOrange:pressed {
    background-color: #B85E3F;
    border-color: #B85E3F;
    color: #17181b;
}

QPushButton#btnOutlineDanger {
    background-color: transparent;
    color: #cc3333;
    border: 1px solid #cc3333;
    border-radius: 5px;
    padding: 6px 18px;
    font-size: 12px;
    font-weight: bold;
    min-width: 90px;
}

QPushButton#btnOutlineDanger:hover {
    background-color: #cc3333;
    color: #17181b;
}

QPushButton#btnOutlineDanger:pressed {
    background-color: #992222;
    border-color: #992222;
    color: #17181b;
}

QFrame#aboutCard {
    background-color: #1a1b1f;
    border: 1px solid #2a2b30;
    border-radius: 8px;
}

QLabel#aboutCardVersion {
    font-size: 18px;
    font-weight: bold;
    color: #D97757;
    background-color: transparent;
}

QLabel#aboutCardMeta {
    font-size: 11px;
    color: #7d7e84;
    background-color: transparent;
    line-height: 1.6;
}


/* ── 용량 추정 정보 바 ──────────────────────────────────────────── */
QLabel#capacityBar {
    background-color: #131417;
    border: 1px dashed #3a3b42;
    border-radius: 4px;
    padding: 6px 10px;
    font-family: "Consolas", monospace;
    font-size: 11px;
    color: #8b8d96;
}

/* ── ROI 단축키 안내 ────────────────────────────────────────────── */
QLabel#roiShortcutLabel {
    font-size: 11px;
    color: #9a9b9e;
    background-color: #1a1b1f;
    border: 1px solid #2a2b30;
    border-radius: 4px;
    padding: 6px 8px;
}
